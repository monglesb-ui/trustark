# Runtime
APP_ENV=local
TRUST_ARK_USE_MOCK_FALLBACK=true

# Server-only secrets. Keep these out of browser code and never prefix them with NEXT_PUBLIC_.
OPENAI_API_KEY=
DATA_GO_KR_SERVICE_KEY_ENCODED=
DATA_GO_KR_SERVICE_KEY_DECODED=
VWORLD_API_KEY=
NAVER_MAP_CLIENT_SECRET=
REAL_ESTATE_PROVIDER_API_KEY=

# Server-only backend routing for API routes or a deployed backend.
TRUST_ARK_API_BASE_URL=http://127.0.0.1:8000

# Browser-visible configuration. These values are exposed in the frontend bundle.
# Leave NEXT_PUBLIC_TRUST_ARK_API_BASE_URL empty on Vercel if you want the app to use the built-in /api/analyze route.
NEXT_PUBLIC_TRUST_ARK_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

# Legacy compatibility. Prefer NEXT_PUBLIC_TRUST_ARK_API_BASE_URL and NEXT_PUBLIC_NAVER_MAP_CLIENT_ID.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_NAVER_MAPS_CLIENT_ID=
