# Runtime
# When true (default), runtime errors in /api/analyze return a degraded report
# with all external data sources marked failed. When false, return HTTP 502.
TRUST_ARK_USE_MOCK_FALLBACK=true

# --- Server-only secrets. Keep these out of browser code and never prefix them with NEXT_PUBLIC_.

# Planner(gpt-4o-mini) + Summarizer(gpt-4o) 에이전트용. 미설정 시 두 단계는 건너뛰고
# 기존 템플릿 결과를 그대로 사용 (graceful degrade).
OPENAI_API_KEY=

# data.go.kr 실거래가 API (인코딩/디코딩 둘 중 사용 가능한 키로 채움)
DATA_GO_KR_SERVICE_KEY_ENCODED=
DATA_GO_KR_SERVICE_KEY_DECODED=

# 건축HUB(건축물대장) API
BUILDING_HUB_SERVICE_KEY_ENCODED=
BUILDING_HUB_SERVICE_KEY_DECODED=

# VWorld 지오코딩
VWORLD_API_KEY=

# 네이버 지도 (서버 사이드 지오코딩용)
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# 네이버 검색 (외부 검색 맥락 에이전트용)
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# CODEF 등기부등본
CODEF_API_HOST=https://development.codef.io
CODEF_PUBLIC_KEY=
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=
CODEF_CONNECTED_ID=
CODEF_REGISTRY_ENDPOINT=
CODEF_REGISTRY_ORGANIZATION=0002
CODEF_REGISTRY_PHONE_NO=
CODEF_REGISTRY_PASSWORD=
CODEF_REGISTRY_PASSWORD_RSA=
CODEF_REGISTRY_INQUIRY_TYPE=3
CODEF_REGISTRY_ISSUE_TYPE=1
CODEF_REGISTRY_REALTY_TYPE=

REAL_ESTATE_PROVIDER_API_KEY=

# 서울 열린데이터광장 (data.seoul.go.kr) 범용 키
# 같은 키로 일반음식점·상권분석·인구통계 등 모든 서울 OpenAPI 서비스 호출 가능.
SEOUL_API_KEY=

# (legacy alias) 일반음식점 전용으로 별도 발급받은 경우. SEOUL_API_KEY와 동일하면 비워둬도 됨.
SEOUL_RESTAURANT_API_KEY=

# 학교알리미 (open.neis.go.kr) - 학교 좌표·정화구역 검증
NEIS_API_KEY=

# 자치법규 (ELIS) / 법제처 OpenAPI - 조례·규칙 본문
# 서버 전용. 브라우저 번들에 노출되지 않도록 NEXT_PUBLIC_ 접두어를 절대 붙이지 마세요.
LAW_API_KEY=

# 소상공인진흥공단 상권정보 (data.go.kr B553077) - 반경 내 상가업소·업종 분포
COMMERCIAL_API_KEY=

# 국토교통부 토지이용계획정보 (LURIS, data.go.kr B551023) - 용도지역·지구단위계획·도시계획시설
LAND_USE_API_KEY=

# --- Browser-visible configuration. These values are exposed in the frontend bundle.

# 네이버 지도 클라이언트 ID (지도 표시용)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
